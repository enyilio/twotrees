---
import Layout from '../layouts/Layout.astro';
import CuteButton from '../components/CuteButton.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);
---

<Layout>

  <!-- ░░ NAVBAR ░░ -->
  <header class="sticky top-0 z-50 bg-cream/85 backdrop-blur border-b border-wood/10">
    <div class="section-wrap flex items-center justify-between h-18 py-2">
      <a href="/" class="flex items-center group">
        <img
          src="https://twotrees.tw/wp-content/uploads/2022/03/twtreeslogo.svg"
          alt="兩棵樹創意行動工作室"
          class="h-12 w-auto group-hover:scale-105 transition-transform duration-300"
        />
      </a>
      <nav class="hidden md:flex items-center gap-7 text-sm font-medium text-bark/70">
        <a href="#services"  class="hover:text-olive transition-colors">服務</a>
        <a href="#about"     class="hover:text-olive transition-colors">關於</a>
        <a href="/blog"      class="hover:text-olive transition-colors">網站知識</a>
        <a href="#contact"   class="hover:text-olive transition-colors">聯絡</a>
      </nav>
      <CuteButton label="合作洽詢" href="mailto:service@twotrees.tw" size="sm" icon="🌿" />
    </div>
  </header>

  <!-- ░░ HERO ░░ -->
  <section class="relative overflow-hidden pt-24 pb-32">
    <div class="pointer-events-none absolute -top-20 -right-20 w-96 h-96 rounded-full bg-leaf/40 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-10 -left-10 w-64 h-64 rounded-full bg-wood-light/20 blur-2xl"></div>

    <div class="section-wrap text-center relative z-10">
      <span class="tag-badge mb-5 inline-block">🌳 兩棵樹創意行動工作室</span>

      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold leading-tight text-olive-dark mb-6">
        從零開始<br/>
        <span class="text-wood relative inline-block">
          打造最亮眼的入口
          <svg class="absolute -bottom-2 left-0 w-full" viewBox="0 0 320 12" fill="none">
            <path d="M2 9 C70 3, 150 11, 220 6 S290 2, 318 8"
              stroke="#A07850" stroke-width="3" stroke-linecap="round" fill="none"/>
          </svg>
        </span>
      </h1>

      <p class="text-bark/60 text-lg max-w-xl mx-auto mb-10 leading-relaxed">
        想要製作網站卻不知從何開始？<br/>
        我們提供免費網站健檢，讓你的品牌在網路上好好發芽。🌱
      </p>

      <div class="flex justify-center">
        <CuteButton label="看看我們的服務" href="#services" size="lg" icon="✨" variant="olive" />
      </div>

      <div class="mt-16 flex justify-center gap-12 text-4xl select-none">
        <span class="animate-float" style="animation-delay:0s">🌿</span>
        <span class="animate-float" style="animation-delay:0.4s">🪵</span>
        <span class="animate-float" style="animation-delay:0.8s">🌳</span>
        <span class="animate-float hidden sm:inline" style="animation-delay:1.2s">☀️</span>
        <span class="animate-float hidden sm:inline" style="animation-delay:1.6s">🍃</span>
      </div>
    </div>
  </section>

  <!-- ░░ SERVICES ░░ -->
  <section id="services" class="py-24 bg-mist">
    <div class="section-wrap">
      <div class="text-center mb-14">
        <span class="tag-badge">我們的服務</span>
        <h2 class="mt-4 text-3xl md:text-4xl">用心為每個品牌打造專屬舞台</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { icon: '🖥️', title: 'WordPress 客製化', desc: '客製化佈景、外掛開發，從零打造屬於你的數位家園。' },
          { icon: '🎨', title: '網站設計',         desc: '響應式設計、動畫效果、金流串接，質感與功能兼顧。' },
          { icon: '☁️', title: '主機代管',         desc: '虛擬主機、VPS 雲端，穩定可靠讓網站全年無休運作。' },
        ].map(s => (
          <div class="card-cute p-8 text-center group cursor-default">
            <div class="text-5xl mb-4 inline-block group-hover:animate-inflate">{s.icon}</div>
            <h3 class="text-xl font-bold text-olive-dark mb-3">{s.title}</h3>
            <p class="text-bark/60 text-sm leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ░░ ABOUT ░░ -->
  <section id="about" class="py-24">
    <div class="section-wrap">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <span class="tag-badge">關於我們</span>
          <h2 class="mt-4 text-3xl md:text-4xl mb-6">品質宣言</h2>
          <p class="text-bark/70 leading-loose mb-4">
            每製作一個網站，對我們來說就像是一個藝術品。
          </p>
          <p class="text-bark/60 leading-loose text-sm mb-8">
            我們將專案時間的 40% 用於規劃與開發，60% 用於與客戶的深度溝通與調整。
            不以低價競爭，以客戶的真實滿意度為最高優先。
          </p>
          <CuteButton label="了解更多" href="#contact" icon="🤝" variant="wood" />
        </div>
        <div class="flex justify-center">
          <div class="relative w-64 h-64">
            <div class="absolute inset-0 rounded-full border-4 border-dashed border-olive/30"
              style="animation: spin 30s linear infinite;"></div>
            <div class="absolute inset-6 rounded-full bg-leaf flex flex-col items-center justify-center shadow-inner">
              <span class="text-5xl animate-float">🌳</span>
              <span class="text-xs font-bold text-olive-dark mt-1">兩棵樹</span>
            </div>
            <div class="absolute -top-2 -right-2 bg-wood text-cream text-xs font-bold px-3 py-1 rounded-full shadow">
              60% 溝通
            </div>
            <div class="absolute -bottom-2 -left-2 bg-olive text-cream text-xs font-bold px-3 py-1 rounded-full shadow">
              40% 開發
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ░░ BLOG / 網站知識 ░░ -->
  <section id="blog" class="py-24 bg-mist">
    <div class="section-wrap">
      <div class="flex items-end justify-between mb-12">
        <div>
          <span class="tag-badge">網站知識</span>
          <h2 class="mt-3 text-3xl md:text-4xl">最新文章</h2>
        </div>
        <a href="/blog" class="text-sm font-semibold text-olive hover:text-olive-dark underline underline-offset-4 transition-colors hidden sm:block">
          查看全部 →
        </a>
      </div>

      <ul class="divide-y divide-wood/10">
        {recentPosts.map(post => {
          const d = new Date(post.data.date).toLocaleDateString('zh-TW', {
            year: 'numeric', month: 'long', day: 'numeric'
          });
          return (
            <li class="group">
              <a href={`/blog/${post.slug}`}
                class="flex items-center justify-between gap-4 py-4 hover:bg-leaf/30 -mx-3 px-3 rounded-lg transition-colors duration-200">
                <span class="font-medium text-bark group-hover:text-olive-dark transition-colors leading-snug">
                  {post.data.title}
                </span>
                <time class="text-xs text-bark/40 whitespace-nowrap shrink-0">{d}</time>
              </a>
            </li>
          );
        })}
      </ul>

      <div class="mt-8 text-center sm:hidden">
        <CuteButton label="查看全部文章" href="/blog" variant="ghost" icon="📖" size="sm" />
      </div>
    </div>
  </section>

  <!-- ░░ CONTACT ░░ -->
  <section id="contact" class="py-24 bg-olive text-cream relative overflow-hidden">
    <div class="pointer-events-none absolute top-0 right-0 w-72 h-72 rounded-full bg-olive-light/30 blur-3xl translate-x-1/3 -translate-y-1/3"></div>
    <div class="section-wrap text-center relative z-10">
      <span class="inline-block text-xs font-bold tracking-widest uppercase bg-cream/20 text-cream px-3 py-1 rounded-full mb-5">
        聯絡我們
      </span>
      <h2 class="text-3xl md:text-5xl font-bold text-cream mb-4">準備好讓品牌發芽了嗎？</h2>
      <p class="text-cream/70 text-lg mb-10 max-w-lg mx-auto">
        立即與我們聯繫，獲得免費網站健檢與專屬報價。
      </p>
      <CuteButton label="立即諮詢" href="mailto:service@twotrees.tw" icon="📬" variant="wood" size="lg" />
    </div>
  </section>

  <!-- ░░ FOOTER ░░ -->
  <footer class="bg-bark text-cream/50 text-xs text-center py-6">
    2026 © 兩棵樹創意行動工作室 twotrees.tw
  </footer>

</Layout>

<style>
  @keyframes spin { to { transform: rotate(360deg); } }
  .h-18 { height: 4.5rem; }
</style>
